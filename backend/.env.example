# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ============================================================================
# SUPABASE (Database + Auth) - Epic 1, 3, 6
# ============================================================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# CLOUDFLARE R2 (Storage S3-compatible) - Epic 3
# ============================================================================
R2_ACCOUNT_ID=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_CONTENT=biblio-content-private
R2_BUCKET_COVERS=biblio-covers-public
R2_PUBLIC_URL=https://cdn.papyri.com

# ============================================================================
# PAYMENT GATEWAYS - Epic 2
# ============================================================================
# Stripe (International)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Flutterwave (Africa/Diaspora)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxx
FLUTTERWAVE_WEBHOOK_HASH=xxx

# ============================================================================
# MEILISEARCH (Search Engine) - Epic 3
# ============================================================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=ChangeMe123456789

# ============================================================================
# EMAIL (Transactional) - Epic 1, 8
# ============================================================================
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@papyri.com
BREVO_SENDER_NAME=Papyri - Bibliothèque Numérique

# ============================================================================
# FIREBASE (Push Notifications) - Epic 8
# ============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============================================================================
# GOOGLE ANALYTICS - Epic 9
# ============================================================================
GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================================================
# JWT (DEPRECATED - Using Supabase Auth now)
# ============================================================================
# JWT_SECRET=
# JWT_REFRESH_SECRET=

# ============================================================================
# ADMINJS (Back-Office) - Epic 10
# ============================================================================
ADMIN_COOKIE_SECRET=your-secure-cookie-secret-32-chars-minimum
ADMIN_SESSION_SECRET=your-secure-session-secret-32-chars-minimum
DATABASE_URL=postgresql://postgres:password@host:5432/database
