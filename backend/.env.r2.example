# ============================================================================
# CLOUDFLARE R2 CONFIGURATION
# ============================================================================
# Copier ces lignes dans votre fichier .env et remplacer les valeurs

# Account ID (trouvé en haut de la page R2)
R2_ACCOUNT_ID=your-account-id-here

# Endpoint URL (format: https://<account-id>.r2.cloudflarestorage.com)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Access Keys (obtenus lors de la création du API Token)
R2_ACCESS_KEY_ID=your-access-key-id-here
R2_SECRET_ACCESS_KEY=your-secret-access-key-here

# Noms des buckets
R2_BUCKET_CONTENT=biblio-content-private
R2_BUCKET_COVERS=biblio-covers-public

# URL publique pour les covers (une de ces options):
# Option 1: Custom domain (si configuré)
R2_PUBLIC_URL=https://cdn.papyri.com
# Option 2: R2.dev subdomain (si pas de custom domain)
# R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# Option 3: Direct R2 URL avec auth (dev uniquement)
# R2_PUBLIC_URL=https://your-account-id.r2.cloudflarestorage.com/biblio-covers-public

